post = read.table("posterior_sample.txt")
head(post)
hist(post$V3)
hist(post$V3, breaks=100)
hist(c(post$V3, post$V8), breaks=100)
hist(c(post$V3, post$V8), breaks=100, xlim=c(0, 100))
hist(c(post$V3, post$V8) < 100, breaks=100)
hist(c(post$V3, post$V8)[c(post$V3, post$V8) < 100], breaks=100)
total_period = c(post$V3, post$V8)
hist(total_period, breaks=50)
hist(total_period[total_period<100], breaks=50)
hist(total_period[total_period<100], breaks=50)
q()
post2 = read.table("posterior_samples.txt")
post2 = read.table("posterior_sample.txt")
head(post2)
combined2 = c(post2$V3, post2$V8)
hist(combined2, breaks=100)
q()

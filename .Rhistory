koi.lda_cv = lda(logged_kepler.df, new.df$target_var, prior=rep(1/3, 3), CV=TRUE)
lda_cv_matrix = table(Predicted = koi.lda_cv$class, Actual = new.df$target_var)
kable(lda_cv_matrix, caption = "Cross-Validated Confusion Matrix for LDA")
par(mfrow=c(1,2))
boxplot(koi_scores_lda$x[,1] ~ new.df$target_var, main="Separation on LD1", col=c("tomato", "gold", "lightblue"))
boxplot(koi_scores_lda$x[,2] ~ new.df$target_var, main="Separation on LD2", col=c("tomato", "gold", "lightblue"))
par(mfrow=c(1,1))
library(MASS)
new.df$target_var = as.factor(new.df$koi_disposition)
koi.lda_cv = lda(logged_kepler.df, new.df$target_var, prior=rep(1/3, 3), CV=TRUE)
lda_cv_matrix = table(Predicted = koi.lda_cv$class, Actual = new.df$target_var)
kable(lda_cv_matrix, caption = "Cross-Validated Confusion Matrix for LDA")
par(mfrow=c(1,2))
boxplot(koi_scores_lda$x[,1] ~ new.df$target_var, main="Separation on LD1", col=c("tomato", "gold", "lightblue"), ylab="LD1", xlab="Class")
boxplot(koi_scores_lda$x[,2] ~ new.df$target_var, main="Separation on LD2", col=c("tomato", "gold", "lightblue"), ylab="LD2", xlab="Class")
par(mfrow=c(1,1))
koi.qda_cv = qda(logged_kepler.df, new.df$target_var, prior=rep(1/3, 3), CV=TRUE)
qda_cv_matrix = table(Predicted = koi.qda_cv$class, Actual = new.df$target_var)
kable(qda_cv_matrix, caption = "Cross-Validated Confusion Matrix for QDA")
koi.qda_cv = qda(logged_kepler.df, new.df$target_var, prior=rep(1/3, 3), CV=TRUE)
qda_cv_matrix = table(Predicted = koi.qda_cv$class, Actual = new.df$target_var)
kable(qda_cv_matrix, caption = "Cross-Validated Confusion Matrix for QDA")
library(mixOmics)
koi.plsda = plsda(X = logged_kepler.df, Y = new.df$target_var, ncomp = 2)
plotIndiv(koi.plsda,
ind.names = FALSE,
legend = TRUE,
ellipse = TRUE,
title = "3-Class PLS-DA of Kepler Objects")
# 2. Run Leave-One-Out Cross-Validation using the perf() function
koi.perf = perf(koi.plsda, validation = 'loo', progressBar = FALSE)
library(MASS)
new.df$target_var = as.factor(new.df$koi_disposition)
model_data = cbind(logged_kepler.df, target_var = new.df$target_var)
# Run LDA using the formula method (target_var ~ .) which prevents row mismatches
koi.lda_cv = lda(target_var ~ ., data = model_data, prior = rep(1/3, 3), CV = TRUE)
# Make the cross-validated confusion matrix
lda_cv_matrix = table(Predicted = koi.lda_cv$class, Actual = model_data$target_var)
kable(lda_cv_matrix, caption = "Cross-Validated Confusion Matrix for LDA")
koi.lda_plot = lda(logged_kepler.df, new.df$target_var, prior=rep(1/3, 3))
koi_scores_plot = predict(koi.lda_plot)
par(mfrow=c(1,2))
boxplot(koi_scores_plot$x[,1] ~ new.df$target_var,
main="Separation on LD1",
col=c("tomato", "gold", "lightblue"),
ylab="LD1 Score")
boxplot(koi_scores_plot$x[,2] ~ new.df$target_var,
main="Separation on LD2",
col=c("tomato", "gold", "lightblue"),
ylab="LD2 Score")
par(mfrow=c(1,1))
library(mixOmics)
koi.plsda = plsda(X = logged_kepler.df, Y = new.df$target_var, ncomp = 2)
plotIndiv(koi.plsda,
ind.names = FALSE,
legend = TRUE,
ellipse = TRUE,
title = "3-Class PLS-DA of Kepler Objects")
# 2. Run Leave-One-Out Cross-Validation using the perf() function
koi.perf = perf(koi.plsda, validation = 'loo', progressBar = FALSE)
library(mixOmics)
koi.plsda = plsda(X = logged_kepler.df, Y = new.df$target_var, ncomp = 2)
plotIndiv(koi.plsda,
ind.names = FALSE,
legend = TRUE,
ellipse = TRUE,
title = "3-Class PLS-DA of Kepler Objects")
# Use 5-fold cross-validation to run instantly
koi.perf = perf(koi.plsda,
validation = 'Mfold',
folds = 5,
nrepeat = 1,          # Only run the 5 folds once
progressBar = FALSE)
# Print the cross-validated error rates
koi.perf$error.rate

# dataset of all values
full_kepler.df = read.csv("cumulative.csv")
interesting_columns = c(
"koi_disposition", "koi_period", "koi_impact", "koi_duration",
"koi_depth", "koi_prad", "koi_teq", "koi_insol",
"koi_steff", "koi_slogg", "koi_srad"
)
kepler.df = na.omit(full_kepler.df[, interesting_columns])
# Remove 0s to allow for Log Transformation (Log(0) = -Inf)
nono_impact = which(kepler.df$koi_impact == 0)
nono_depth = which(kepler.df$koi_depth == 0)
nono_insol = which(kepler.df$koi_insol == 0)
new.df = kepler.df[-c(nono_impact, nono_depth, nono_insol), ]
logged_kepler.df = log(new.df[, -1]) # Log all continuous predictors
library(corrplot)
cor_matrix = cor(logged_kepler.df)
corrplot(cor_matrix, method="square", type="upper",
tl.col="black", tl.srt=45, title="Correlation of Logged Variables", mar=c(0,0,1,0))
# need to scale because wildly different units
planets.pr = prcomp(logged_kepler.df, scale. = TRUE)
variance_explained = round(planets.pr$sdev^2 / sum(planets.pr$sdev^2), 2)
head(variance_explained)
library(MASS)
new.df$target_var = as.factor(new.df$koi_disposition)
koi.lda = lda(logged_kepler.df, new.df$target_var, prior=rep(1/3, 3))
koi_scores_lda = predict(koi.lda)
table(Predicted = koi_scores_lda$class, Actual = new.df$target_var)
par(mfrow=c(1,2))
boxplot(koi_scores_lda$x[,1] ~ new.df$target_var, main="Separation on LD1", col=c("tomato", "gold", "lightblue"))
boxplot(koi_scores_lda$x[,2] ~ new.df$target_var, main="Separation on LD2", col=c("tomato", "gold", "lightblue"))
par(mfrow=c(1,1))
koi.qda = qda(logged_kepler.df, new.df$target_var, prior=rep(1/3, 3))
koi_scores_qda = predict(koi.qda)
table(Predicted = koi_scores_qda$class, Actual = new.df$target_var)
library(mixOmics)
koi.plsda = plsda(X = logged_kepler.df, Y = new.df$target_var, ncomp = 2)
plotIndiv(koi.plsda,
ind.names = FALSE,
legend = TRUE,
ellipse = TRUE,
title = "3-Class PLS-DA of Kepler Objects")
# Confusion Matrix for PLS-DA
plsda_preds = predict(koi.plsda, newdata = logged_kepler.df)
table(Predicted = plsda_preds$class$max.dist[, 2], Actual = new.df$target_var)
